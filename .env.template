# Environment Variables Template
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and should not be committed

# Docmost Configuration
APP_SECRET=your_generated_app_secret_here  # Generate with: openssl rand -hex 32
APP_URL=http://your_server_ip:4389

# PostgreSQL Database Configuration
POSTGRES_DB=docmost
POSTGRES_USER=docmost
POSTGRES_PASSWORD=your_strong_database_password_here

# Database URL for Docmost (update with your actual password)
DATABASE_URL=postgresql://docmost:your_strong_database_password_here@docmost_db:5432/docmost?schema=public

# Redis Configuration
REDIS_URL=redis://redis:6379

# Ollama Configuration
OLLAMA_BASE_URL=http://ollama:11434