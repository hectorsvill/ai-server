# Copy this file to `.env` and fill in values as needed.
# This file is used by docker-compose variable substitution.

# --- Open WebUI ---
# Ollama runs natively on the host (not in Docker) for direct AMD ROCm GPU access.
# Open WebUI connects to it via host.docker.internal, which resolves to the host gateway.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Docmost application ---
# Public URL where Docmost will be accessed from your browser
APP_URL=http://localhost:4389

# Generate a strong secret with:  openssl rand -hex 32
APP_SECRET=replace_with_output_of_openssl_rand_hex_32

# Connection string to PostgreSQL used by Docmost
# Make sure the username, password and database match the values below.
DATABASE_URL=postgresql://docmost:YOUR_STRONG_PASSWORD@docmost_db:5432/docmost?schema=public

# Redis connection string for Docmost (default database 0)
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (for Docmost) ---
POSTGRES_DB=docmost
POSTGRES_USER=docmost
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD

# --- Host port mappings ---
# Change these if host ports are in use or need to be customized
OPEN_WEBUI_PORT=3234
GLANCE_PORT=11457
DOCMOST_PORT=4389
