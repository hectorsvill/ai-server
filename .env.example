# Copy this file to `.env` and fill in values as needed.
# This file is used by docker-compose variable substitution.

# --- Caddy reverse proxy + HTTPS ---
# Your root domain (e.g. yourdomain.com). Caddy will serve:
#   https://webui.DOMAIN   → Open WebUI
#   https://docs.DOMAIN    → Docmost
#   https://dash.DOMAIN    → Glance
#   https://n8n.DOMAIN     → n8n
DOMAIN=yourdomain.com

# Cloudflare API token with "Edit zone DNS" permission.
# Create at: Cloudflare → My Profile → API Tokens → Edit zone DNS template.
# Only shown once — store it in ~/.credentials/ai-server.txt as well.
CF_API_TOKEN=your_cloudflare_api_token_here

# --- Open WebUI ---
# Ollama runs natively on the host (not in Docker) for direct AMD ROCm GPU access.
# Open WebUI connects to it via host.docker.internal, which resolves to the host gateway.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Docmost application ---
# Public URL where Docmost is accessed. Use the HTTPS subdomain if Caddy is set up,
# otherwise use the direct IP + port.
APP_URL=https://docs.yourdomain.com

# Generate a strong secret with:  openssl rand -hex 32
APP_SECRET=replace_with_output_of_openssl_rand_hex_32

# Connection string to PostgreSQL used by Docmost
# Make sure the username, password and database match the values below.
DATABASE_URL=postgresql://docmost:YOUR_STRONG_PASSWORD@docmost_db:5432/docmost?schema=public

# Redis connection string for Docmost (default database 0)
REDIS_URL=redis://redis:6379/0

# --- PostgreSQL (for Docmost) ---
POSTGRES_DB=docmost
POSTGRES_USER=docmost
POSTGRES_PASSWORD=YOUR_STRONG_PASSWORD

# --- Host port mappings (direct access, bypassing Caddy) ---
# Change these if host ports are in use or need to be customized.
# These ports remain active even after Caddy is set up, as a fallback.
OPEN_WEBUI_PORT=3234
GLANCE_PORT=11457
DOCMOST_PORT=4389
N8N_PORT=5679

# --- n8n ---
# Key used to encrypt saved credentials in n8n. Generate with: openssl rand -hex 32
# Changing this after first run will break existing credentials.
N8N_ENCRYPTION_KEY=replace_with_output_of_openssl_rand_hex_32

# --- Backup ---
# Destination directory on the external drive for tools/backup.sh
BACKUP_DEST=/media/yourname/DRIVE_LABEL/Backups

# --- AI Guardian ---
# Telegram bot for alerts and two-way control. Create a bot via @BotFather,
# then get your chat ID by messaging @userinfobot.
GUARDIAN_TELEGRAM_TOKEN=your_telegram_bot_token_here
GUARDIAN_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# GUARDIAN_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# GUARDIAN_SLACK_WEBHOOK=https://hooks.slack.com/services/...

# --- Tailscale ---
# Tailscale IPv4 of this machine. Run: tailscale ip -4
# Point your Cloudflare DNS A records (webui/wiki/dash.DOMAIN) to this IP
# to make services reachable from any device on your tailnet.
TAILSCALE_IP=100.x.x.x
